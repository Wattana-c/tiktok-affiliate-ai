# ==========================================
# Backend Configuration
# ==========================================

# Database URLs
DATABASE_URL=postgresql://user:password@db:5432/tiktok_affiliate_db
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==========================================
# AI Configuration (IMPORTANT)
# ==========================================

# OpenAI API Key to generate real content
# If left completely blank, the system will fall back to using Smart Mock Content
OPENAI_API_KEY=your_openai_api_key_here

# ==========================================
# System Rules Configuration (Optional overrides)
# ==========================================

# Any custom score rules can be set here.
# AUTO_POST_THRESHOLD=80
# MANUAL_REVIEW_THRESHOLD=50
